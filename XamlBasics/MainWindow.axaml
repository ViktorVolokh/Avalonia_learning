<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="XamlBasics.MainWindow"
        Title="XamlBasics">
        <StackPanel Orientation="Vertical" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" 
                     
                    Spacing="20">
                <Button Content="left side" Width="200" Height="60" 
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"/>
                
                <Button Content="Center" Width="200" Height="60"
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"/> 
                
                
                <Button Content="right side" Width="200" Height="60"
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"/>  
                </StackPanel>
                <TextBlock Text="click on center to begin!" Margin="238,5,0,0"/>
        </StackPanel>
        
        
</Window>
